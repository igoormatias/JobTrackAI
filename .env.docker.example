# Docker Compose development environment reference
# Copy to .env at repo root if you customize compose overrides.
# Do not commit real secrets.

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=jobtrack

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/jobtrack
DIRECT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/jobtrack
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3333
NEXT_PUBLIC_ENABLE_MSW=false
JWT_SECRET=dev-secret-change-in-production
