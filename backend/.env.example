# Server
PORT=3333
NODE_ENV=development

# Database (local Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/jobtrack

# Direct connection for Prisma migrations (required with Supabase pooler in production)
# Local: same as DATABASE_URL. Production: db.<project>.supabase.co:5432
DIRECT_DATABASE_URL=postgresql://postgres:postgres@localhost:5434/jobtrack

# Auth (JWT_SECRET — aliases: AUTH_SECRET, SESSION_SECRET)
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — production: full Vercel URL; multiple origins comma-separated
FRONTEND_URL=http://localhost:3000

# Google OAuth (required)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Calendar OAuth redirect (defaults to FRONTEND_URL/settings/calendar/callback)
GOOGLE_CALENDAR_REDIRECT_URI=
# Encrypts stored calendar tokens (falls back to JWT_SECRET)
CALENDAR_TOKEN_SECRET=

# Logging — never set LOG_PRETTY=true on Vercel
# LOG_LEVEL=info

# AI Career Intelligence (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PROMPT_VERSION=career-v1
GEMINI_TIMEOUT_MS=30000
AI_CAREER_DAILY_LIMIT=5
AI_CAREER_DEBOUNCE_MS=15000

# Vercel: set VERCEL=1 automatically; backend mounts at /api/backend
