# Server
PORT=3333
NODE_ENV=development

# Database (Docker — host exposto na porta 5433 para não conflitar com Postgres local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/jobtrack

# Database (dentro do Docker Compose — hostname `postgres`)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/jobtrack

# Database (Postgres nativo no Windows na porta 5432 — ajuste user/senha)
# DATABASE_URL=postgresql://postgres:SUA_SENHA@localhost:5432/jobtrack

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Google OAuth (required)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI Career Intelligence (Etapa 18 — optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PROMPT_VERSION=career-v1
GEMINI_TIMEOUT_MS=30000
AI_CAREER_DAILY_LIMIT=5
AI_CAREER_DEBOUNCE_MS=15000
