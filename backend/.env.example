# Server
PORT=3333
NODE_ENV=development

# Database (local)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobtrack

# Database (Docker — use host `postgres` instead of `localhost`)
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/jobtrack

# Auth
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000

# Google OAuth (optional in development)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
