generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  name          String
  avatarUrl     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  profile       Profile?
  settings      UserSettings?
  jobs          Job[]
  trackings     JobTracking[]
  notifications Notification[]
  jobViews      JobView[]
  userSkills    UserSkill[]
  aiUsageLogs   AIAnalysisUsageLog[]
  resume        Resume?
  resumeImports ResumeImport[]
  resumeAnalyses ResumeAnalysis[]
  resumeAnalysisUsageLogs ResumeAnalysisUsageLog[]
  calendarIntegration     CalendarIntegration?
}

model Job {
  id          String        @id @default(cuid())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName String
  companySlug String?
  title       String
  slug        String
  description String?
  sourceUrl   String?
  source      String
  externalId  String?
  contentHash String?
  area        String?
  seniority   String?
  modality    String?
  location    String?
  salaryMin   Int?
  salaryMax   Int?
  currency    String        @default("BRL")
  status      String        @default("active")
  isCatalog   Boolean       @default(false)
  publishedAt DateTime      @default(now())
  expiresAt   DateTime?
  lastCheckedAt DateTime?
  removedAt   DateTime?
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  trackings   JobTracking[]
  views       JobView[]

  @@unique([source, externalId])
  @@index([isCatalog])
  @@index([isCatalog, status, publishedAt])
  @@index([userId])
  @@index([companySlug])
  @@index([area])
  @@index([seniority])
  @@index([modality])
  @@index([source])
  @@index([publishedAt])
  @@index([status])
  @@index([contentHash])
  @@index([sourceUrl])
}

model JobProviderRegistry {
  id           String    @id @default(cuid())
  name         String    @unique
  displayName  String
  enabled      Boolean   @default(true)
  lastHealthAt DateTime?
  lastRunAt    DateTime?
  config       Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProviderExecution {
  id              String       @id @default(cuid())
  providerName    String
  status          String
  startedAt       DateTime     @default(now())
  finishedAt      DateTime?
  durationMs      Int?
  foundCount      Int          @default(0)
  importedCount   Int          @default(0)
  duplicateCount  Int          @default(0)
  failedCount     Int          @default(0)
  errorMessage    String?
  jobImports      JobImport[]

  @@index([providerName, startedAt])
  @@index([status])
}

model JobImport {
  id           String            @id @default(cuid())
  executionId  String
  execution    ProviderExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)
  providerName String
  externalId   String?
  sourceUrl    String?
  contentHash  String?
  status       String
  jobId        String?
  errorMessage String?
  createdAt    DateTime          @default(now())

  @@index([executionId])
  @@index([providerName])
  @@index([contentHash])
}

model JobView {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId    String
  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  viewedAt DateTime @default(now())

  @@unique([userId, jobId])
  @@index([userId])
}

model JobTracking {
  id                 String          @id @default(cuid())
  userId             String
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId              String
  job                Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  stage              String
  status             String          @default("active")
  isFavorite         Boolean         @default(false)
  priority           String          @default("MEDIUM")
  visibility         String          @default("VISIBLE")
  hiddenAt           DateTime?
  notes              String?
  feedback           String?
  recruiterName      String?
  recruiterEmail     String?
  recruiterPhone     String?
  recruiterLinkedin  String?
  tags               String[]        @default([])
  negotiatedSalary   Int?
  salaryExpectation  Json?
  processLinks       Json?
  nextInterviewAt    DateTime?
  rulesMatchScore    Int?
  rulesMatchLabel    String?
  rulesMatchReasons  Json?
  aiAnalysisStatus   String          @default("PENDING")
  aiMatchScore       Int?
  aiAnalyzedAt       DateTime?
  resumeHash         String?
  profileHash        String?
  jobContentHash     String?
  lastStageUpdatedAt DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  timelineEvents     TimelineEvent[]
  interviews         Interview[]
  aiAnalyses         AIAnalysis[]

  @@unique([userId, jobId])
  @@index([userId, stage])
  @@index([userId, isFavorite])
  @@index([userId, priority])
  @@index([userId, visibility])
  @@index([userId, aiAnalysisStatus])
}

model TimelineEvent {
  id          String      @id @default(cuid())
  trackingId  String
  tracking    JobTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  type        String
  title       String
  occurredAt  DateTime
  notes       String?
  metadata    Json?
  createdById String
  createdAt   DateTime    @default(now())

  @@index([trackingId])
}

model Interview {
  id                String      @id @default(cuid())
  trackingId        String
  tracking          JobTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  scheduledAt       DateTime
  timezone          String?
  location          String?
  meetingType       String?
  link              String?
  notes             String?
  calendarEventId   String?
  calendarProvider  String?
  syncStatus        String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([trackingId, scheduledAt])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  area                String?
  seniority           String?
  modality            String?
  location            String   @default("")
  locationPreference  Json?
  salaryBand          String?
  salaryExpectation   Json?
  skillNames          String[] @default([])
  onboardingCompleted Boolean  @default(false)
  onboardingProgress  Json?
  updatedAt           DateTime @updatedAt
}

model UserSettings {
  id                            String   @id @default(cuid())
  userId                        String   @unique
  user                          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                         String   @default("dark")
  jobRefreshFrequency           String   @default("1h")
  dashboardNotificationInterval String   @default("1h")
  calendarPromptDismissedAt     DateTime?
  updatedAt                     DateTime @updatedAt
}

model Skill {
  id         String       @id @default(cuid())
  slug       String       @unique
  name       String
  status     String       @default("OFFICIAL")
  area       String?
  aliases    SkillAlias[]
  userSkills UserSkill[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model SkillAlias {
  id        String @id @default(cuid())
  aliasSlug String @unique
  skillId   String
  skill     Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
}

model UserSkill {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  level   String @default("INTERMEDIATE")
  status  String @default("OFFICIAL")

  @@unique([userId, skillId])
  @@index([userId])
}

model AIAnalysis {
  id                 String      @id @default(cuid())
  trackingId         String
  tracking           JobTracking @relation(fields: [trackingId], references: [id], onDelete: Cascade)
  contentHash        String
  result             Json
  provider           String      @default("gemini")
  model              String
  promptVersion      String
  matchEngineVersion String
  confidence         Float?
  generatedAt        DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([trackingId, contentHash])
  @@index([trackingId, generatedAt])
}

model AIAnalysisUsageLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackingId       String?
  wasCached        Boolean  @default(false)
  durationMs       Int?
  model            String?
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model Resume {
  id               String           @id @default(cuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentVersionId String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  versions         ResumeVersion[]
  analyses         ResumeAnalysis[]
}

model ResumeVersion {
  id                 String             @id @default(cuid())
  resumeId           String
  resume             Resume             @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  versionNumber      Int
  content            Json
  contentHash        String
  source             String
  createdAt          DateTime           @default(now())
  imports            ResumeImport[]
  analyses           ResumeAnalysis[]
  appliedSuggestions ResumeSuggestion[] @relation("AppliedVersion")

  @@unique([resumeId, versionNumber])
  @@index([resumeId, versionNumber(sort: Desc)])
  @@index([contentHash])
}

model ResumeImport {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  format        String
  status        String
  rawTextLength Int            @default(0)
  fileHash      String?
  errorMessage  String?
  versionId     String?
  version       ResumeVersion? @relation(fields: [versionId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())

  @@index([userId, createdAt])
}

model ResumeAnalysis {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId           String
  resume             Resume             @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  resumeVersionId    String
  resumeVersion      ResumeVersion      @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  jobSourceUrl       String
  jobExternalId      String?
  jobTitle           String?
  jobCompany         String?
  contentHash        String
  result             Json
  matchScore         Int                @default(0)
  atsScore           Int                @default(0)
  provider           String             @default("gemini")
  model              String
  promptVersion      String
  matchEngineVersion String
  generatedAt        DateTime           @default(now())
  suggestions        ResumeSuggestion[]

  @@unique([userId, contentHash])
  @@index([userId, generatedAt])
  @@index([resumeVersionId])
}

model ResumeSuggestion {
  id               String         @id @default(cuid())
  analysisId       String
  analysis         ResumeAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  type             String
  section          String
  reason           String
  impact           String
  suggestedText    String
  status           String         @default("pending")
  appliedVersionId String?
  appliedVersion   ResumeVersion? @relation("AppliedVersion", fields: [appliedVersionId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([analysisId, status])
}

model ResumeAnalysisUsageLog {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysisId       String?
  wasCached        Boolean  @default(false)
  durationMs       Int?
  model            String?
  promptTokens     Int?
  completionTokens Int?
  createdAt        DateTime @default(now())

  @@index([userId, createdAt])
}

model CalendarIntegration {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String    @default("google")
  accessToken  String
  refreshToken String
  tokenExpiry  DateTime?
  calendarId   String?
  scope        String?
  accountEmail String?
  lastSyncAt   DateTime?
  lastError    String?
  connectedAt  DateTime  @default(now())
  revokedAt    DateTime?
  updatedAt    DateTime  @updatedAt
}
