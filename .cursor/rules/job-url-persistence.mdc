---
description: Persist provider URLs in sourceUrl — never reconstruct
globs:
  - backend/src/providers/**
  - backend/src/modules/job-aggregation/**
  - backend/src/modules/job-import/**
  - backend/prisma/seeders/**
  - frontend/src/lib/jobs/**
alwaysApply: false
