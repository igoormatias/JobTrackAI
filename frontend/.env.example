# Public site URL (metadata, sitemap, Open Graph)
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API base URL
# Local: http://localhost:3333
# Vercel production (same domain): /api/backend
NEXT_PUBLIC_API_URL=http://localhost:3333

# Google OAuth client ID (required — from Google Cloud Console)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Enable MSW mock API during development (true | false) — must be false in production
NEXT_PUBLIC_ENABLE_MSW=false

# Realtime transport: polling (default) | socket (requires ENABLE_REALTIME on backend)
NEXT_PUBLIC_REALTIME_TRANSPORT=polling
